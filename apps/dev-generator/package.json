    "@repo/typescript-config": "workspace:*",
    "@types/node": "^20",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.21.0",
    "typescript": "5.5.4"
  }
}
